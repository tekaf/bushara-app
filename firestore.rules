rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /invites/{inviteId} {
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || resource.data.status == 'active';
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.ownerId);

      match /guests/{guestId} {
        allow read: if isAdmin() || isOwner(get(/databases/$(database)/documents/invites/$(inviteId)).data.ownerId);
        allow write: if isAdmin() || isOwner(get(/databases/$(database)/documents/invites/$(inviteId)).data.ownerId);
      }
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /checkin_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.staffUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /renders/{renderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /presets/{presetType} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin/server operational collections (production hardening).
    match /invitation_internal/{inviteId} {
      allow read, write: if isAdmin();
    }

    match /invitation_reviews/{reviewId} {
      allow read, write: if isAdmin();
    }

    match /risk_case_dispatches/{inviteId} {
      allow read, write: if isAdmin();

      match /entries/{guestId} {
        allow read, write: if isAdmin();
      }
    }

    match /risk_case_waves/{waveId} {
      allow read, write: if isAdmin();
    }

    match /risk_case_access_links/{tokenId} {
      allow read, write: if isAdmin();
    }

    match /send_jobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /send_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /dispatch_kernel_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /dispatch_kernel_locks/{lockId} {
      allow read, write: if isAdmin();
    }

    match /analytics_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /admin_notifications/{notificationId} {
      allow read, write: if isAdmin();
    }
  }
}

